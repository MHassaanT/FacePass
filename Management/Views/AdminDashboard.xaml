<UserControl x:Class="FacePass.Management.Views.AdminDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0D0D0D">
    <TabControl Background="Transparent" BorderThickness="0" Margin="10">
        
        <!-- User Management Tab -->
        <TabItem Header="User Management" Foreground="White">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
                    <Button Content="+ Add User" Width="100" Height="30" Background="#00E676" Foreground="Black" FontWeight="Bold" Click="AddUser_Click"/>
                    <Button Content="Refresh" Width="80" Height="30" Margin="10,0" Background="#333" Foreground="White" Click="RefreshUsers_Click"/>
                </StackPanel>

                <DataGrid x:Name="UsersGrid" Grid.Row="1" Background="#111" Foreground="White" 
                          BorderBrush="#333" RowBackground="#1A1A1A" AutoGenerateColumns="True"
                          CanUserAddRows="False"/>
            </Grid>
        </TabItem>

        <!-- Audit Logs Tab -->
        <TabItem Header="Audit Logs" Foreground="White">
            <Grid Margin="10">
                <DataGrid x:Name="AuditGrid" Background="#111" Foreground="White" 
                          BorderBrush="#333" RowBackground="#1A1A1A" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="180"/>
                        <DataGridTextColumn Header="Actor" Binding="{Binding ActorName}" Width="150"/>
                        <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="120"/>
                        <DataGridTextColumn Header="Metadata" Binding="{Binding Metadata}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </TabItem>

    </TabControl>
</UserControl>
