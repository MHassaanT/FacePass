<Window x:Class="FacePass.Management.Views.BiometricRegistrationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Biometric Registration" Height="550" Width="700"
        WindowStyle="ToolWindow" WindowStartupLocation="CenterOwner"
        Background="#111" Loaded="Window_Loaded" Closing="Window_Closing">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Column: Camera Feed -->
        <Border Grid.Column="0" Background="Black" BorderBrush="#333" BorderThickness="0,0,1,0">
            <Grid>
                <Image x:Name="CameraFeed" Stretch="UniformToFill"/>
                <Canvas>
                    <Rectangle x:Name="FaceBoundingBox" Stroke="#00E676" StrokeThickness="3" Visibility="Collapsed"/>
                </Canvas>
            </Grid>
        </Border>

        <!-- Right Column: Controls -->
        <StackPanel Grid.Column="1" Margin="20" VerticalAlignment="Center">
            <TextBlock Text="Registering:" Foreground="#CCC" FontSize="14" Margin="0,0,0,5"/>
            <TextBlock x:Name="StudentNameText" Text="Student Name" Foreground="#00E676" FontSize="20" FontWeight="Bold" Margin="0,0,0,30" TextWrapping="Wrap"/>

            <TextBlock x:Name="StatusText" Text="Position face in the frame..." Foreground="#CCC" FontSize="14" Margin="0,0,0,20" TextWrapping="Wrap"/>

            <Button x:Name="CaptureBtn" Content="Capture &amp; Save" Height="40" Background="#00E676" Foreground="Black" FontWeight="Bold" Margin="0,0,0,10" Click="CaptureBtn_Click"/>
            <Button x:Name="CancelBtn" Content="Cancel" Height="30" Background="#333" Foreground="White" Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
