<Window x:Class="FacePass.Management.Views.TimetableDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Timetable Slot" Height="500" Width="400"
        WindowStartupLocation="CenterOwner" Background="#0D0D0D"
        WindowStyle="ToolWindow" Foreground="White">
    <Window.Resources>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="30">
        <StackPanel>
            <TextBlock Text="Timetable Slot" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>

            <TextBlock Text="Day of Week" Foreground="#88FFFFFF" Margin="0,0,0,5"/>
            <ComboBox x:Name="DayCombo" Height="35">
                <ComboBoxItem Content="Monday"/>
                <ComboBoxItem Content="Tuesday"/>
                <ComboBoxItem Content="Wednesday"/>
                <ComboBoxItem Content="Thursday"/>
                <ComboBoxItem Content="Friday"/>
                <ComboBoxItem Content="Saturday"/>
            </ComboBox>

            <TextBlock Text="Course" Foreground="#88FFFFFF" Margin="0,15,0,5"/>
            <ComboBox x:Name="CourseCombo" Height="35" DisplayMemberPath="name"/>

            <TextBlock Text="Start Time" Foreground="#88FFFFFF" Margin="0,15,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="StartHourCombo" Grid.Column="0" Height="35"
                          DisplayMemberPath="." />
                <TextBlock Grid.Column="1" Text=":" Foreground="White"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           FontSize="18" FontWeight="Bold"/>
                <ComboBox x:Name="StartMinuteCombo" Grid.Column="2" Height="35"
                          DisplayMemberPath="." />
                <ComboBox x:Name="StartAmPmCombo" Grid.Column="4" Height="35">
                    <ComboBoxItem Content="AM"/>
                    <ComboBoxItem Content="PM"/>
                </ComboBox>
            </Grid>

            <TextBlock Text="End Time" Foreground="#88FFFFFF" Margin="0,15,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="EndHourCombo" Grid.Column="0" Height="35"
                          DisplayMemberPath="." />
                <TextBlock Grid.Column="1" Text=":" Foreground="White"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           FontSize="18" FontWeight="Bold"/>
                <ComboBox x:Name="EndMinuteCombo" Grid.Column="2" Height="35"
                          DisplayMemberPath="." />
                <ComboBox x:Name="EndAmPmCombo" Grid.Column="4" Height="35">
                    <ComboBoxItem Content="AM"/>
                    <ComboBoxItem Content="PM"/>
                </ComboBox>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                <Button Content="Save" Width="100" Height="40" Background="#00E676" Foreground="Black" FontWeight="Bold" Click="Save_Click" BorderThickness="0"/>
                <Button Content="Cancel" Width="80" Height="40" Margin="10,0,0,0" Background="#333" Foreground="White" Click="Cancel_Click" BorderThickness="0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
