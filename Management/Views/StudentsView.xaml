<UserControl x:Class="FacePass.Management.Views.StudentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:FacePass.Management.Converters"
             Background="#0D0D0D">
    <UserControl.Resources>
        <!-- Boolean to Brush converter for enrollment status -->
        <conv:BoolToBrushConverter x:Key="BoolToBrushConverter" />
        <!-- Boolean to Status Text converter -->
        <conv:BoolToStatusConverter x:Key="BoolToStatusConverter" />
    </UserControl.Resources>
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20" Orientation="Horizontal" HorizontalAlignment="Stretch" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Students Roster" FontSize="26" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Manage registered student profiles, view facial encodings state and enrollment history" FontSize="14" Foreground="#88FFFFFF" Margin="0,5,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,0,0,0">
                <Button x:Name="RegisterBiometricBtn" Content="Register Biometric" Width="120" Height="30" Margin="0,0,10,0" IsEnabled="False" Background="#FF5252" Click="RegisterBiometric_Click"/>
                <Button Content="Refresh" Width="80" Height="30" Click="RefreshButton_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- Placeholder layout with pre-populated DataGrid -->
        <Border Grid.Row="1" Background="#1A1A1A" CornerRadius="8" BorderBrush="#333" BorderThickness="1" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="StudentsGrid" Grid.Row="0" Background="Transparent" Foreground="White" 
                          BorderThickness="0" RowBackground="#1A1A1A" AlternatingRowBackground="#151515"
                          AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="None"
                          CanUserAddRows="False" CanUserResizeRows="False" SelectionMode="Single"
                          HeadersVisibility="Column" HorizontalGridLinesBrush="#222"
                          SelectionChanged="StudentsGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Student Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                        <DataGridTextColumn Header="Date Created" Binding="{Binding DateCreated}" Width="150"/>
                        <DataGridTemplateColumn Header="Biometric Status" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="4,2" Background="{Binding BiometricEnrolled, Converter={StaticResource BoolToBrushConverter}}">
                                        <TextBlock Text="{Binding BiometricEnrolled, Converter={StaticResource BoolToStatusConverter}}" Foreground="White" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                    <DataGrid.Resources>
                        <!-- Header Styling -->
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#00E676"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="BorderBrush" Value="#333"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        </Style>
                        <!-- Row Styling -->
                        <Style TargetType="DataGridRow">
                            <Setter Property="BorderBrush" Value="#222"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="Padding" Value="5"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2A2A2A"/>
                                    <Setter Property="Foreground" Value="#00E676"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <!-- Cell Styling -->
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <!-- No custom template needed; default works -->
                        </Style>
                    </DataGrid.Resources>
                </DataGrid>

                <!-- Footer overlay indicating Phase 2 implementation -->
                <!-- Footer placeholder removed for final implementation -->
            </Grid>
        </Border>
    </Grid>
</UserControl>
