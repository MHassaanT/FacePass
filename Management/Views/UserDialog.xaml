<Window x:Class="FacePass.Management.Views.UserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage User" Height="680" Width="420"
        WindowStartupLocation="CenterOwner" Background="#111"
        WindowStyle="ToolWindow" Foreground="White">

    <Window.Resources>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="User Information" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>

                <TextBlock Text="Full Name" Foreground="#88FFFFFF" Margin="0,0,0,5"/>
                <TextBox x:Name="NameBox" Height="35" VerticalContentAlignment="Center"/>

                <TextBlock Text="Email Address" Foreground="#88FFFFFF" Margin="0,15,0,5"/>
                <TextBox x:Name="EmailBox" Height="35" VerticalContentAlignment="Center"/>

                <TextBlock Text="Password" Foreground="#88FFFFFF" Margin="0,15,0,5"/>
                <PasswordBox x:Name="PassBox" Height="35"/>

                <TextBlock Text="Role" Foreground="#88FFFFFF" Margin="0,15,0,5"/>
                <ComboBox x:Name="RoleCombo" Height="35" SelectionChanged="RoleCombo_SelectionChanged">
                    <ComboBoxItem Content="student"/>
                    <ComboBoxItem Content="teacher"/>
                    <ComboBoxItem Content="admin"/>
                </ComboBox>

                <StackPanel x:Name="DepartmentPanel" Visibility="Collapsed">
                    <TextBlock Text="Department" Foreground="#88FFFFFF" Margin="0,15,0,5"/>
                    <ComboBox x:Name="DepartmentCombo" Height="35" DisplayMemberPath="name"
                              SelectionChanged="DepartmentCombo_SelectionChanged"/>
                </StackPanel>

                <StackPanel x:Name="CoursePanel" Visibility="Collapsed">
                    <TextBlock Text="Course" Foreground="#88FFFFFF" Margin="0,15,0,5"/>
                    <ComboBox x:Name="CourseCombo" Height="35" DisplayMemberPath="name"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                    <Button Content="Save User" Width="100" Height="40" Background="#00E676" Foreground="Black" FontWeight="Bold" Click="Save_Click"/>
                    <Button Content="Cancel" Width="80" Height="40" Margin="10,0,0,0" Background="#333" Foreground="White" Click="Cancel_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
