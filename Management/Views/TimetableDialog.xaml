<Window x:Class="FacePass.Management.Views.TimetableDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Timetable Slot" Height="500" Width="400"
        WindowStartupLocation="CenterOwner" Background="#0D0D0D"
        WindowStyle="ToolWindow" Foreground="White">
    <Window.Resources>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="30">
        <StackPanel>
            <TextBlock Text="Timetable Slot" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>

            <TextBlock Text="Day of Week" Foreground="#88FFFFFF" Margin="0,0,0,5"/>
            <ComboBox x:Name="DayCombo" Height="35">
                <ComboBoxItem Content="Monday"/>
                <ComboBoxItem Content="Tuesday"/>
                <ComboBoxItem Content="Wednesday"/>
                <ComboBoxItem Content="Thursday"/>
                <ComboBoxItem Content="Friday"/>
                <ComboBoxItem Content="Saturday"/>
            </ComboBox>

            <TextBlock Text="Course" Foreground="#88FFFFFF" Margin="0,15,0,5"/>
            <ComboBox x:Name="CourseCombo" Height="35" DisplayMemberPath="name"/>

            <TextBlock Text="Start Time (e.g. 08:00)" Foreground="#88FFFFFF" Margin="0,15,0,5"/>
            <TextBox x:Name="StartTimeBox" Height="35"/>

            <TextBlock Text="End Time (e.g. 09:30)" Foreground="#88FFFFFF" Margin="0,15,0,5"/>
            <TextBox x:Name="EndTimeBox" Height="35"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                <Button Content="Save" Width="100" Height="40" Background="#00E676" Foreground="Black" FontWeight="Bold" Click="Save_Click" BorderThickness="0"/>
                <Button Content="Cancel" Width="80" Height="40" Margin="10,0,0,0" Background="#333" Foreground="White" Click="Cancel_Click" BorderThickness="0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
