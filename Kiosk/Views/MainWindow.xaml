<Window
    x:Class="FacePass.Kiosk.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:FacePass.Kiosk.Converters"
    Title="FacePass Kiosk"
    Height="720" Width="1280"
    WindowStyle="None"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    Background="#0D0D0D">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <!-- Root Grid -->
    <Grid>

        <!-- ① Live Camera Feed -->
        <Image
            x:Name="CameraImage"
            Source="{Binding CameraFrame}"
            Stretch="UniformToFill"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Opacity="0.92" />

        <!-- ② Dark vignette overlay -->
        <Border>
            <Border.Background>
                <RadialGradientBrush Center="0.5,0.5" RadiusX="0.7" RadiusY="0.7">
                    <GradientStop Color="Transparent"     Offset="0" />
                    <GradientStop Color="#BB000000"       Offset="1" />
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <!-- ③ Face Bounding Box (Canvas overlay) -->
        <Canvas IsHitTestVisible="False">
            <Rectangle
                x:Name="FaceBoundingBox"
                Canvas.Left="{Binding FaceRect.X}"
                Canvas.Top="{Binding FaceRect.Y}"
                Width="{Binding FaceRect.Width}"
                Height="{Binding FaceRect.Height}"
                Stroke="#00E676"
                StrokeThickness="3"
                RadiusX="6" RadiusY="6"
                Visibility="{Binding FaceVisible, Converter={StaticResource BoolToVis}}">
                <Rectangle.Effect>
                    <DropShadowEffect Color="#00E676" BlurRadius="12" ShadowDepth="0" />
                </Rectangle.Effect>
            </Rectangle>
        </Canvas>

        <!-- ④ Top Header Bar -->
        <Border
            VerticalAlignment="Top"
            HorizontalAlignment="Stretch"
            Height="60"
            Background="#CC0D0D0D">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="20,0">
                    <Ellipse Width="10" Height="10" Fill="#00E676" Margin="0,0,10,0">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#00E676" BlurRadius="8" ShadowDepth="0" />
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock
                        Text="FacePass"
                        FontSize="22"
                        FontFamily="Segoe UI"
                        FontWeight="SemiBold"
                        Foreground="White" />
                    <TextBlock
                        Text=" — Biometric Attendance"
                        FontSize="16"
                        FontFamily="Segoe UI"
                        Foreground="#88FFFFFF"
                        VerticalAlignment="Bottom"
                        Margin="4,0,0,2" />
                </StackPanel>

                <TextBlock
                    Grid.Column="1"
                    x:Name="ClockText"
                    FontSize="16"
                    FontFamily="Segoe UI"
                    Foreground="#AAFFFFFF"
                    VerticalAlignment="Center"
                    Margin="0,0,24,0" />
            </Grid>
        </Border>

        <!-- ⑤ Liveness Challenge Prompt -->
        <Border
            VerticalAlignment="Top"
            HorizontalAlignment="Center"
            Margin="0,70,0,0"
            CornerRadius="10"
            Padding="24,12"
            Visibility="{Binding ChallengeVisible, Converter={StaticResource BoolToVis}}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#CC1565C0" Offset="0" />
                    <GradientStop Color="#CC0D47A1" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#1565C0" BlurRadius="20" ShadowDepth="0" />
            </Border.Effect>
            <TextBlock
                Text="{Binding ChallengeText}"
                FontSize="30"
                FontFamily="Segoe UI"
                FontWeight="Bold"
                Foreground="White"
                HorizontalAlignment="Center" />
        </Border>

        <!-- ⑥ QR Code (bottom-right) -->
        <Border
            VerticalAlignment="Bottom"
            HorizontalAlignment="Right"
            Margin="0,0,24,24"
            CornerRadius="12"
            Padding="10"
            Background="#EE1A1A1A"
            Visibility="{Binding QrVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock
                    Text="Scan to Mark Attendance"
                    FontSize="11"
                    FontFamily="Segoe UI"
                    Foreground="#AAFFFFFF"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,6" />
                <Image
                    Source="{Binding QrSource}"
                    Width="180" Height="180"
                    RenderOptions.BitmapScalingMode="NearestNeighbor" />
                <TextBlock
                    Text="Refreshes every 30 seconds"
                    FontSize="10"
                    FontFamily="Segoe UI"
                    Foreground="#66FFFFFF"
                    HorizontalAlignment="Center"
                    Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <!-- ⑦ Success Banner (bottom-centre) -->
        <Border
            VerticalAlignment="Bottom"
            HorizontalAlignment="Center"
            Margin="0,0,0,40"
            CornerRadius="14"
            Padding="32,16"
            Visibility="{Binding BannerVisible, Converter={StaticResource BoolToVis}}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#CC00C853" Offset="0" />
                    <GradientStop Color="#CC1B5E20" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#00C853" BlurRadius="24" ShadowDepth="0" />
            </Border.Effect>
            <TextBlock
                Text="{Binding BannerText}"
                FontSize="28"
                FontFamily="Segoe UI"
                FontWeight="SemiBold"
                Foreground="White"
                HorizontalAlignment="Center" />
        </Border>

        <!-- ⑧ Bottom instruction text -->
        <TextBlock
            Text="Please look directly at the camera"
            FontSize="14"
            FontFamily="Segoe UI"
            Foreground="#55FFFFFF"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="0,0,0,12" />
    </Grid>
</Window>
