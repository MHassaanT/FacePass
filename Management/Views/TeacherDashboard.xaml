<UserControl x:Class="FacePass.Management.Views.TeacherDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0D0D0D">
    
    <UserControl.Resources>
        <!-- Premium Sidebar Button Style -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#88FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0,0,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Left Sidebar Navigation Panel -->
            <ColumnDefinition Width="200"/>
            <!-- Main Content Area -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Panel -->
        <Border Grid.Column="0" Background="#111" BorderBrush="#333" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Sidebar Brand Header -->
                <StackPanel Grid.Row="0" Margin="20,25,20,25">
                    <TextBlock Text="DASHBOARD" FontSize="11" FontWeight="Bold" Foreground="#00E676"/>
                    <TextBlock Text="Faculty Hub" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Sidebar Navigation Buttons -->
                <StackPanel Grid.Row="1">
                    <!-- Timetable Button -->
                    <Button x:Name="BtnTimetable" Style="{StaticResource SidebarButton}" Click="BtnTimetable_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M2 5a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5zm14-1H4a1 1 0 0 0-1 1v1h14V5a1 1 0 0 0-1-1zM3 8v9a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V8H3z" 
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" 
                                  Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Timetable" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Students Button -->
                    <Button x:Name="BtnStudents" Style="{StaticResource SidebarButton}" Click="BtnStudents_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1H7zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm-5.784 6A2.238 2.238 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.325 6.325 0 0 0 5 9c-4 0-5 3-5 4 0 1 1 1 1 1h4.216zM4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z" 
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" 
                                  Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Students" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Current Button -->
                    <Button x:Name="BtnCurrent" Style="{StaticResource SidebarButton}" Click="BtnCurrent_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z M6.25 5C5.56 5 5 5.56 5 6.25v3.5c0 .69.56 1.25 1.25 1.25H7l3.2-2a1.25 1.25 0 0 0 0-2.1L7 5.75h-.75z" 
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" 
                                  Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Current" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Sidebar Footer Status -->
                <Border Grid.Row="2" Background="#0A0A0A" BorderBrush="#222" BorderThickness="0,1,0,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="PORTAL STATUS" FontSize="9" FontWeight="Bold" Foreground="#88FFFFFF"/>
                        <TextBlock Text="Connected" FontSize="12" FontWeight="SemiBold" Foreground="#00E676" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

        <!-- Main Content Area Container -->
        <ContentControl Grid.Column="1" x:Name="ActiveViewContainer" Background="#0D0D0D"/>

    </Grid>
</UserControl>
